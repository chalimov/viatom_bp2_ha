{
  "domain": "viatom_bp2",
  "name": "Viatom BP2 Blood Pressure Monitor",
  "codeowners": ["@chalimov"],
  "config_flow": true,
  "dependencies": ["bluetooth"],
  "homeassistant": "2025.1.0",
  "documentation": "https://github.com/chalimov/viatom_bp2_ha",
  "bluetooth": [
    {
      "service_uuid": "14839ac4-7d7e-415c-9a42-167340cf2339",
      "connectable": true
    },
    {
      "local_name": "BP2*",
      "connectable": true
    },
    {
      "local_name": "BP2A*",
      "connectable": true
    },
    {
      "local_name": "LP-BP2*",
      "connectable": true
    },
    {
      "local_name": "Checkme BP2*",
      "connectable": true
    }
  ],
  "integration_type": "device",
  "iot_class": "local_push",
  "requirements": ["bleak>=0.21.1", "bleak-retry-connector>=3.4.0"],
  "version": "0.1.0"
}
